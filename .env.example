# Telegram Bot Token
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Shared workspace root (optional)
# Example: /Volumes/AI_DATA_CENTRE/AI_WORKSPACE
WAVETREE_WORKSPACE_ROOT=

# Optional explicit deploy/news-hub paths (override auto-detection)
WAVETREE_DEPLOY_DIR=
NEWS_HUB_DIR=

# Optional custom output paths
TARGET_HTML_PATH=
DASHBOARD_DATA_FILE=
